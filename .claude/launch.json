{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dist/server/server.js"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 3000,
      "autoPort": true,
      "env": {
        "NODE_ENV": "production"
      }
    }
  ]
}
