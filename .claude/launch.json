{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "watch", "server.ts"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "vite",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--config", "vite.config.ts", "--host", "0.0.0.0"],
      "port": 5173
    },
    {
      "name": "prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dist/server/server.js"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
