{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dist/server/server.js"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "preview",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "set NODE_ENV=production&& npm run build && node dist/server/server.js"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
