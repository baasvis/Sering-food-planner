generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Batch {
  id                String   @id
  name              String
  type              String
  serving           Int      @default(280)
  allergens         String[]
  extraAllergens    String[] @map("extra_allergens")
  orderFor          Boolean  @default(false) @map("order_for")
  cookDate          String?  @map("cook_date")
  note              String   @default("")
  services          Json     @default("[]")
  createdAt         String   @map("created_at")
  recipeId          String?  @map("recipe_id")
  actualIngredients Json?    @map("actual_ingredients")
  cookNotes         String   @default("") @map("cook_notes")
  stockDeducted     Boolean  @default(false) @map("stock_deducted")
  generated         Boolean  @default(false)
  // Unified-batch model: per-(loc,storage) inventory entries + in-flight
  // shipments. The legacy cols (stock/storage/location/inTransit/parentId
  // + v1 recipe fields) and the parent self-FK are removed by the manual
  // drop-cols psql step in prisma/migrations/DEPLOY.md, applied right after
  // data-migrate populates these JSON columns.
  inventory         Json     @default("[]")
  shipments         Json     @default("[]")
  recipe            Recipe?  @relation("BatchRecipe", fields: [recipeId], references: [id])

  @@index([cookDate])
  @@index([recipeId])
  @@map("batches")
}

model Guest {
  id       Int    @id @default(autoincrement())
  location String
  day      String
  lunch    Int    @default(0)
  dinner   Int    @default(0)

  @@unique([location, day])
  @@map("guests")
}

model Catering {
  id             String  @id
  name           String  @default("")
  date           String?
  guestCount     Int     @default(0) @map("guest_count")
  deliveryMode   String  @default("pickup") @map("delivery_mode")
  dishes         Json    @default("[]")
  toppings       Json    @default("[]")
  logisticsNotes String  @default("") @map("logistics_notes")
  createdAt      String  @map("created_at")

  @@map("caterings")
}

model TransportItem {
  id   String @id
  text String

  @@map("transport_items")
}

model Ingredient {
  id               String                @id
  name             String                @default("")
  supplierName     String                @default("") @map("supplier_name")
  types            Json                  @default("[]")
  category         String                @default("")
  unit             String                @default("Grams")
  supplier         String                @default("")
  orderCode        String                @default("") @map("order_code")
  orderUnit        String                @default("") @map("order_unit")
  orderPrice       Float?                @map("order_price")
  priceLevel       String                @default("") @map("price_level")
  priceHistory     Json                  @default("[]") @map("price_history")
  priceAlert       Boolean               @default(false) @map("price_alert")
  storageLocations Json                  @default("{}") @map("storage_locations")
  stock            Json                  @default("{}")
  nutrition        Json                  @default("{}")
  allergens        String                @default("")
  notes            String                @default("")
  active           Boolean               @default(true)
  orderUnitSize    Float                 @default(0) @map("order_unit_size")
  pricePer100      Float                 @default(0) @map("price_per_100")
  measureMode      String                @default("weight") @map("measure_mode")
  targetStock      Json                  @default("{}") @map("target_stock")
  recipeUsages     RecipeIngredientRow[]

  @@index([active])
  @@index([category])
  @@map("ingredients")
}

model GuestHistory {
  id       Int    @id @default(autoincrement())
  location String
  meal     String
  date     String
  count    Int    @default(0)

  @@unique([location, meal, date])
  @@map("guest_history")
}

model GuestHistoryMeta {
  key   String @id
  value String

  @@map("guest_history_meta")
}

model GuestsNextWeeks {
  id        Int    @id @default(autoincrement())
  mondayKey String @map("monday_key")
  location  String
  day       String
  meal      String
  count     Int    @default(0)

  @@unique([mondayKey, location, day, meal])
  @@index([mondayKey])
  @@map("guests_next_weeks")
}

model Log {
  id        Int    @id @default(autoincrement())
  timestamp String
  email     String
  name      String
  action    String
  details   String

  @@index([timestamp])
  @@map("log")
}

// Active login sessions. Previously held in-process in a Map, which meant
// every Railway redeploy logged everyone out (the cookie was still valid for
// 7 days but the in-memory state was gone). Persisting here closes the
// "I keep getting logged off" feedback loop and also removes a multi-replica
// blocker. expiresAt mirrors the cookie's maxAge.
model Session {
  id        String   @id
  email     String
  name      String
  picture   String?
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("sessions")
}

// Account-access requests + grants. The effective login allowlist is the
// union of CONFIG.ALLOWED_EMAILS (env, the bootstrap backbone) and the rows
// here with status="approved". A new person signs in with Google, which
// records a "pending" row; a director approves it (status -> "approved") and
// the person can then log in — no env-var edit / redeploy needed. Revoking an
// approved user flips status to "revoked". Env-listed emails are never stored
// here and can't be revoked from the UI (so a director can't lock themselves
// out). See routes/auth.ts (isEmailAllowed) and routes/access.ts.
model AccessRequest {
  id          String    @id
  email       String    @unique
  name        String // display name = "firstName lastName" (or the Google name on the auto-queue fallback)
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  picture     String?
  status      String    @default("pending") // "pending" | "approved" | "denied" | "revoked"
  requestedAt DateTime  @default(now()) @map("requested_at")
  decidedAt   DateTime? @map("decided_at")
  decidedBy   String?   @map("decided_by") // director email who approved/denied/revoked
  // Training (competencies) person created/linked on approval. Lets the
  // approved account be the source of that person's name; see routes/access.ts.
  personId    String?   @map("person_id")
  // Role-based page permissions. Null = full edit (preserves legacy behavior for
  // env-listed / pre-role users); a non-null role maps each screen to a level.
  roleId      String?   @map("role_id")

  @@index([status])
  @@map("access_requests")
}

// Role-based page permissions — frontend guardrails only (no server-side write
// enforcement). `permissions` maps each gateable screen id to
// "hidden" | "view" | "edit"; an AccessRequest.roleId links a user to one role.
// Directors (DIRECTOR_EMAILS) bypass roles entirely (full edit). Resolved into
// the AppUser at login / GET /auth/me — see routes/auth.ts (resolvePermissions)
// and the frontend nav/view gating in public/js/navigate.ts.
model Role {
  id          String   @id
  name        String
  permissions Json     @default("{}") // { [screenId]: "hidden" | "view" | "edit" }
  isDefault   Boolean  @default(false) @map("is_default") // assigned to newly-approved users
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Feedback {
  id        Int     @id @default(autoincrement())
  timestamp String
  user      String  @default("anonymous")
  type      String  @default("general")
  screen    String  @default("")
  text      String
  userAgent String  @default("") @map("user_agent")
  processed Boolean @default(false)

  @@index([processed])
  @@map("feedback")
}

model StandardInventory {
  id       String @id
  name     String
  amount   Float
  unit     String
  location String @default("west")

  @@map("standard_inventory")
}

model PrepChecklist {
  id        Int      @id @default(autoincrement())
  loc       String
  date      String
  checked   Json     @default("[]")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([loc, date])
  @@map("prep_checklist")
}

// Per-(location, date) set of completed daily-ritual step keys (e.g.
// "fmm-lunch", "service-dinner", "stocktake"). Backs the dashboard "Today"
// guidance panel. Modelled exactly on PrepChecklist: a JSON array of done
// step-key strings, overwritten wholesale on save so tick/untick is trivial.
// Only steps with no observable domain signal are stored here; steps backed
// by real state (inventory, cookDate, shipments) are derived, never stored.
model RitualCompletion {
  id        Int      @id @default(autoincrement())
  loc       String
  date      String
  completed Json     @default("[]")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([loc, date])
  @@map("ritual_completions")
}

model StorageConfig {
  id     String @id @default("default")
  config Json   @default("{}")

  @@map("storage_config")
}

model KitchenEquipment {
  id                 String @id @default("default")
  pots               Json   @default("[]") // array of liter sizes, e.g. [140, 140, 100, 100, ...]
  gasBurners         Int    @default(0) @map("gas_burners") // burners that can handle pots > 80L
  inductionBurners   Int    @default(0) @map("induction_burners") // burners that handle pots ≤ 80L
  bigBurnerThreshold Int    @default(80) @map("big_burner_threshold") // pot size that requires a gas burner

  @@map("kitchen_equipment")
}

model CookRhythm {
  id     String @id @default("default")
  config Json   @default("{}") // { days: { Mon: { soup, main, chefs }, ... } } — editable Fix My Menu rules

  @@map("cook_rhythm")
}

model ClosedServices {
  id     String @id @default("default")
  config Json   @default("{}") // { recurring: { <loc>: { <weekday>: Meal[] } }, dates?: {...} } — closed-service schedule

  @@map("closed_services")
}

// Controllable targets for the live finance dashboard (staff screen). config:
//   { <venue>: { foodPerMeal: number|null, drinkPerMeal: number|null,
//                labourByDay: { Mon: number|null, ..., Sun: number|null } } }
// venue = west | centraal | testtafel. foodPerMeal/drinkPerMeal are € that
// staff influence via upselling; labourByDay is a € labour-cost target per
// weekday. No revenue target by design (covers/footfall aren't controllable).
model FinanceTargets {
  id     String @id @default("default")
  config Json   @default("{}")

  @@map("finance_targets")
}

model DailyRevenue {
  id           Int    @id @default(autoincrement())
  date         String
  location     String
  grossRevenue Float  @default(0) @map("gross_revenue")
  netRevenue   Float  @default(0) @map("net_revenue")
  sales        Int    @default(0)
  covers       Int    @default(0)
  invoiceCount Int    @default(0) @map("invoice_count")
  syncedAt     String @map("synced_at")

  @@unique([date, location])
  @@map("daily_revenue")
}

model ProductRevenue {
  id              Int    @id @default(autoincrement())
  date            String
  location        String
  meal            String
  productName     String @map("product_name")
  productCategory String @default("") @map("product_category")
  quantity        Float  @default(0)
  grossRevenue    Float  @default(0) @map("gross_revenue")
  netRevenue      Float  @default(0) @map("net_revenue")
  syncedAt        String @map("synced_at")

  @@unique([date, location, meal, productName])
  @@map("product_revenue")
}

model Recipe {
  id             String                @id
  name           String
  type           String                @default("Soup")
  structure      String                @default("")
  seasonality    String                @default("")
  servingTemp    String                @default("") @map("serving_temp")
  servingSize    Int                   @default(280) @map("serving_size")
  recipeVolume   Float?                @map("recipe_volume")
  // Yield mode: 'volume' (soups/mains — scaled by liters, the default when
  // null) or 'count' (toppings & bread — scaled by discrete outputCount of
  // outputUnit, e.g. "makes 10 loaves").
  yieldType      String?               @map("yield_type")
  outputCount    Float?                @map("output_count")
  outputUnit     String?               @map("output_unit")
  autoAllergens  String[]              @map("auto_allergens")
  extraAllergens String[]              @map("extra_allergens")
  costPerServing Float?                @map("cost_per_serving")
  avgSkill       Float                 @default(0) @map("avg_skill")
  avgSpeed       Float                 @default(0) @map("avg_speed")
  avgBanger      Float                 @default(0) @map("avg_banger")
  timesServed    Int                   @default(0) @map("times_served")
  prepSteps      Json                  @default("[]") @map("prep_steps")
  coolingMethod  String                @default("") @map("cooling_method")
  storageMethod  String                @default("") @map("storage_method")
  photoUrl       String?               @map("photo_url")
  isComplete     Boolean               @default(false) @map("is_complete")
  versions       Json                  @default("[]")
  createdBy      String                @default("") @map("created_by")
  createdAt      String                @map("created_at")
  updatedAt      String                @map("updated_at")
  legacySheetId  String?               @map("legacy_sheet_id")
  batches        Batch[]               @relation("BatchRecipe")
  ingredients    RecipeIngredientRow[]
  photo          RecipePhoto?
  supplies       Supply[]              @relation("SupplyRecipe")

  @@index([type])
  @@map("recipes")
}

// Supply: toppings, breads, ferments, pickles, sauces. Standard supplies have a
// per-guest ratio + replenishment; one-offs drip-feed across services until
// depleted, then auto-archive. preservationMethod is a tag for a future
// PreservationProject feature (Lacto ferment / Sugar preservation / etc.) — see
// the planning doc; out of scope for this PR.
model Supply {
  id                 String   @id
  name               String
  kind               String   // 'standard' | 'oneoff'
  unit               String   // 'g' | 'pieces' | 'jars' | 'ml' | ...
  recipeId           String?  @map("recipe_id")
  recipe             Recipe?  @relation("SupplyRecipe", fields: [recipeId], references: [id])

  // standard-only fields (null for oneoff)
  guestsPerUnit      Float?   @map("guests_per_unit")  // guests served by one unit (e.g. 10 = 1 box per 10 guests)
  prepHorizonDays    Int?     @map("prep_horizon_days")
  prepMode           String?  @map("prep_mode")  // 'centralized' | 'per-location'

  // oneoff-only fields (null for standard)
  oneoffLocation     String?  @map("oneoff_location")  // 'west' | 'centraal'
  unitsPerService    Float?   @map("units_per_service")
  oneoffStartDate    String?  @map("oneoff_start_date")  // ISO 'YYYY-MM-DD'

  stock              Json     @default("{}")  // { west: { amount, lastMakeDate }, centraal: { amount, lastMakeDate } }
  costPerUnit        Float?   @map("cost_per_unit")  // € per unit; drives price-per-guest = costPerUnit / guestsPerUnit
  preservationMethod String?  @map("preservation_method")
  archived           Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([archived])
  @@index([kind])
  @@map("supplies")
}

model RecipeIngredientRow {
  id             String      @id
  recipeId       String      @map("recipe_id")
  ingredientId   String?     @map("ingredient_id")
  sortOrder      Int         @default(0) @map("sort_order")
  rawAmount      Float       @map("raw_amount")
  cookedAmount   Float?      @map("cooked_amount")
  unit           String      @default("Grams")
  isFlexible     Boolean     @default(false) @map("is_flexible")
  flexCategory   String?     @map("flex_category")
  flexLabel      String?     @map("flex_label")
  suggestedNames String[]    @map("suggested_names")
  ingredient     Ingredient? @relation(fields: [ingredientId], references: [id])
  recipe         Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

model RecipePhoto {
  id        String @id
  recipeId  String @unique @map("recipe_id")
  mimeType  String @map("mime_type")
  data      Bytes
  createdAt String @map("created_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_photos")
}

model TelemetryEvent {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  source    String
  type      String
  name      String
  data      Json?
  userId    String?  @map("user_id")
  sessionId String?  @map("session_id")

  @@index([timestamp])
  @@index([type, timestamp])
  @@index([source, type])
  @@map("telemetry_event")
}

model AiInsight {
  id         Int       @id @default(autoincrement())
  timestamp  DateTime  @default(now())
  category   String
  severity   String
  title      String
  body       String
  data       Json?
  status     String    @default("new")
  resolvedAt DateTime? @map("resolved_at")

  @@index([status, timestamp])
  @@index([category])
  @@map("ai_insight")
}

// Tebi L1 capture (plan §1.4). One row per Tebi invoice header. Hub writes;
// planner doesn't read it today but the table lives in the planner-owned
// schema per the §1.10 schema-authority discipline.
//
// `profitCenterId` + `profitCenterName` are nullable in Phase 1 because the
// Tebi invoice list endpoint silently ignores the per-PC `filter` param —
// invoices come back at ledger granularity, not per-PC. Per-PC attribution
// happens in Phase 2 via `Sales5MinBucket` (cross-reference invoice
// timestamps × per-PC product_top data). Don't backfill these by ledger
// heuristic in Phase 1 — Account 1 has held different PCs over time and a
// constant per-account label would mis-attribute historical rows when we
// backfill.
//
// **Phase 2 maintainer warning:** the Phase 1 Hub worker sets
// `profitCenterId` and `profitCenterName` to `null` in BOTH the upsert
// `create` AND `update` payloads (sources/tebi/worker.ts:upsertTebiInvoices).
// Harmless today — nothing populates these at L1. But if Phase 2 ever
// enriches these columns at L1 (vs. L2-only enrichment in Sales5MinBucket),
// the worker's `update` path will silently clobber any backfilled value on
// the next re-sync. Fix at that point: omit the PC fields from the update
// payload, or set them only on create.
//
// Indexes pre-created so the Phase 2 enrichment doesn't pay the
// add-index-to-populated-table cost.
model TebiInvoice {
  id               Int       @id @default(autoincrement())
  ledger           String
  profitCenterId   String?   @map("profit_center_id")
  profitCenterName String?   @map("profit_center_name")
  invoiceKey       String    @map("invoice_key")
  sequenceNumber   String?   @map("sequence_number")
  name             String?
  businessDay      String    @map("business_day")
  createdAt        DateTime  @map("created_at")
  closedTime       DateTime? @map("closed_time")
  grossRevenue     Decimal   @map("gross_revenue") @db.Decimal(10, 2)
  netRevenue       Decimal   @map("net_revenue") @db.Decimal(10, 2)
  guest            Int?
  receiptUrl       String?   @map("receipt_url")
  syncedAt         DateTime  @default(now()) @map("synced_at")

  @@unique([ledger, invoiceKey])
  @@index([businessDay])
  @@index([profitCenterName, businessDay])
  @@map("tebi_invoice")
}

// ── Sering Hub L1/L2 tables (Hub plan §2.1) ──
//
// Written and read by the Hub ONLY (sering-hub repo). They live in the
// planner-owned schema per the §1.10 schema-authority discipline: the planner
// runs `prisma migrate deploy`; the Hub copies this schema and runs
// `prisma generate` only. Planner code must not read or write these tables.
//
// L1 = rawest format the upstream exposes; L2 = materialised single-source
// interpretation, recomputed incrementally by the Hub's
// lib/layers/l2/recompute.ts after each Tebi sync.
//
// `org` is the Hub/planner location key: 'west' | 'centraal' | 'testtafel'.
// Currency is Decimal(10,2); btwRate is Decimal(5,4) (e.g. 0.0900).

// L1: raw per-day per-profit-center product_top rows, exactly as Tebi returns
// them — BEFORE the TestTafel↔Centraal misattribution reassignment that
// ProductRevenue rows carry. No net column: product_top only exposes gross;
// net is an L2 interpretation via per-Type BTW rates.
model TebiProductDaily {
  id               Int      @id @default(autoincrement())
  ledger           String
  profitCenterId   String   @map("profit_center_id")
  profitCenterName String   @map("profit_center_name") // PC label as discovered: west|centraal|testtafel
  date             String // YYYY-MM-DD business day
  productName      String   @map("product_name")
  quantity         Float    @default(0)
  grossRevenue     Decimal  @map("gross_revenue") @db.Decimal(10, 2)
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@unique([ledger, profitCenterId, date, productName])
  @@index([date])
  @@index([profitCenterName, date])
  @@map("tebi_product_daily")
}

// L2: 5-minute sales buckets from TebiInvoice.createdAt (Europe/Amsterdam).
// `org` attribution for ledger 724466 evenings is heuristic — see the Hub's
// sources/tebi/org-attribution.ts.
//
// `source` ('tebi' | 'lightspeed') scopes each upstream's recompute deletes
// on this and the other daily L2 tables — TestTafel rows come from Lightspeed
// before the ~2026-05 POS switch and from Tebi after, and the two recomputes
// must not clobber each other (Hub plan §3.5).
model Sales5MinBucket {
  id         Int      @id @default(autoincrement())
  org        String
  source     String   @default("tebi")
  date       String // YYYY-MM-DD business day
  hourMinute Int      @map("hour_minute") // minutes since local midnight, 5-min steps
  count      Int      @default(0)
  gross      Decimal  @db.Decimal(10, 2)
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([source, org, date, hourMinute])
  @@index([date])
  @@map("sales_5min_bucket")
}

// L2: hourly sales from TebiInvoice (same org attribution as Sales5MinBucket).
model SalesHour {
  id         Int      @id @default(autoincrement())
  org        String
  source     String   @default("tebi")
  date       String
  hour       Int // 0-23, Europe/Amsterdam
  sales      Int      @default(0) // invoice count
  gross      Decimal  @db.Decimal(10, 2)
  net        Decimal  @db.Decimal(10, 2)
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([source, org, date, hour])
  @@index([date])
  @@map("sales_hour")
}

// L2: per-day per-org totals. gross/net come from Tebi's per-PC revenue
// charts (exact, as-rung-up — currently mirrored in DailyRevenue per-loc
// rows); sales/covers come from org-attributed TebiInvoice rows. The two
// sources are deliberately mixed per-field — each field uses its most
// reliable upstream.
model SalesDay {
  id         Int      @id @default(autoincrement())
  org        String
  source     String   @default("tebi")
  date       String
  gross      Decimal  @db.Decimal(10, 2)
  net        Decimal  @db.Decimal(10, 2)
  sales      Int      @default(0)
  covers     Int      @default(0)
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([source, org, date])
  @@index([date])
  @@map("sales_day")
}

// L2: per-day per-org per-product rows from TebiProductDaily, with the
// misattribution reassignment applied and `type` derived from the Hub's
// productNameToType(). type=null means uncategorized (surfaced in the
// dashboard). net = gross / (1 + btwRate-of-type).
model ProductDay {
  id          Int      @id @default(autoincrement())
  org         String
  source      String   @default("tebi")
  date        String
  productName String   @map("product_name")
  type        String?
  qty         Float    @default(0)
  gross       Decimal  @db.Decimal(10, 2)
  net         Decimal  @db.Decimal(10, 2)
  computedAt  DateTime @default(now()) @map("computed_at")

  @@unique([source, org, date, productName])
  @@index([date])
  @@index([org, type, date])
  @@map("product_day")
}

// L2: per-day per-Type aggregates from ProductDay. regtype mirrors the xlsx
// Revenue-input convention: REGULAR (POS) vs INVOICES (catering, Phase 3).
model TypeDay {
  id         Int      @id @default(autoincrement())
  org        String
  source     String   @default("tebi")
  date       String
  type       String
  regtype    String   @default("REGULAR")
  count      Float    @default(0) // sum of product quantities
  gross      Decimal  @db.Decimal(10, 2)
  net        Decimal  @db.Decimal(10, 2)
  btwRate    Decimal  @map("btw_rate") @db.Decimal(5, 4)
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([source, org, date, type, regtype])
  @@index([date])
  @@map("type_day")
}

// L2: ISO-week per-Type revenue — the Hub's equivalent of the xlsx "Revenue
// input" sheet. regtype is part of the unique key so REGULAR (Tebi) and
// INVOICES (catering, Phase 3) rows coexist; the Hub's recompute touches
// only its own regtype scope (scope-by-regtype invariant, plan §2.3).
// count semantics: REGULAR = sum of product quantities; INVOICES = guest
// count from the catering line item (null if not specified).
model WeeklyRevenue {
  id         Int      @id @default(autoincrement())
  org        String
  year       Int
  week       Int // ISO week 1-53
  type       String
  regtype    String   @default("REGULAR")
  count      Float?
  gross      Decimal  @db.Decimal(10, 2)
  btwRate    Decimal  @map("btw_rate") @db.Decimal(5, 4)
  computedAt DateTime @default(now()) @map("computed_at")

  // btwRate is part of the key: a catering invoice routinely splits one Type
  // across 9% and 21% rows (food vs alcohol/rental) — xlsx §5.6 convention.
  @@unique([org, year, week, type, regtype, btwRate])
  @@index([year, week])
  @@map("weekly_revenue")
}

// L2: ISO-week guest counts from TebiProductDaily via the meal allowlist.
// meal ∈ 'lunch' | 'dinner' | 'staff' — EXCLUSIVE counts (staff is NOT
// folded into lunch/dinner here, unlike GuestHistory which folds a 30/70
// staff split into its lunch/dinner rows).
model WeeklyGuests {
  id         Int      @id @default(autoincrement())
  org        String
  year       Int
  week       Int
  meal       String
  count      Int      @default(0)
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([org, year, week, meal])
  @@index([year, week])
  @@map("weekly_guests")
}

// L2 (populated in Hub Phase 3 from TimeclockEntry; schema lands now so the
// planner only deploys one Hub migration): ISO-week hours per role.
model WeeklyHours {
  id         Int      @id @default(autoincrement())
  org        String
  year       Int
  week       Int
  role       String
  hours      Decimal  @db.Decimal(10, 2)
  hourlyRate Decimal  @map("hourly_rate") @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([org, year, week, role])
  @@index([year, week])
  @@map("weekly_hours")
}

// L2 (populated in Hub Phase 3 from FoodcostInvoice): ISO-week food costs
// per supplier source (Hanos / Lindenhoff / groenhartig / ...).
model WeeklyFoodcost {
  id         Int      @id @default(autoincrement())
  org        String
  year       Int
  week       Int
  source     String
  gross      Decimal  @db.Decimal(10, 2)
  btwRate    Decimal  @map("btw_rate") @db.Decimal(5, 4)
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([org, year, week, source])
  @@index([year, week])
  @@map("weekly_foodcost")
}

// L2 (populated in Hub Phase 3/4 from ManualLineItem + expanded
// RecurringLineItem + ComputedCell): ISO-week cost line items.
model WeeklyLineItem {
  id         Int      @id @default(autoincrement())
  org        String
  year       Int
  week       Int
  label      String
  amount     Decimal  @db.Decimal(10, 2)
  btwRate    Decimal  @map("btw_rate") @db.Decimal(5, 4)
  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([org, year, week, label])
  @@index([year, week])
  @@map("weekly_line_item")
}

// ── Hub Phase 3 L1 tables (plan §3.1-§3.5) ──

// L1: one row per Connecteam timeclock shift (timesheet_overview xlsx export,
// "All Employees" sheet). `jobType` is the raw Connecteam job name — the
// Hub's role mapping translates it to (org, reader role, rate) at L2 time.
model TimeclockEntry {
  id         Int      @id @default(autoincrement())
  person     String // "First Last"
  jobType    String   @map("job_type")
  start      DateTime
  end        DateTime
  hours      Float    @default(0) // from the export's "Shift hours" column
  sourceFile String   @default("") @map("source_file")
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@unique([person, start, jobType])
  @@index([start])
  @@map("timeclock_entry")
}

// L1: manual hours rows that don't come from the timeclock — the weekly
// "Daan hours" (38h admin), the interns/special-contracts total, and ad-hoc
// corrections. `hours`/`hourlyRate` may be null for total-only rows.
model HoursAdjustment {
  id         Int      @id @default(autoincrement())
  org        String
  year       Int
  week       Int
  role       String
  hours      Decimal? @db.Decimal(10, 2)
  hourlyRate Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  notes      String   @default("")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([year, week])
  @@map("hours_adjustment")
}

// L1: one row per foodcost invoice (manual entry; Hanos / Lindenhoff /
// Groenhartig / …). PDF parsing is a deferred follow-up.
model FoodcostInvoice {
  id           Int      @id @default(autoincrement())
  org          String
  year         Int
  week         Int
  source       String
  gross        Decimal  @db.Decimal(10, 2)
  btwRate      Decimal  @map("btw_rate") @db.Decimal(5, 4)
  clientNumber String   @default("") @map("client_number")
  notes        String   @default("")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([year, week])
  @@map("foodcost_invoice")
}

// L1: catering invoices + their BTW-split line items. The L2 recompute rolls
// line items into WeeklyRevenue rows with regtype='INVOICES', week taken
// from the EVENT date (not the invoice date).
model CateringInvoice {
  id            Int      @id @default(autoincrement())
  factuurNumber String   @default("") @map("factuur_number")
  eventDate     String   @map("event_date") // YYYY-MM-DD
  description   String   @default("")
  createdAt     DateTime @default(now()) @map("created_at")

  items CateringInvoiceLineItem[]

  @@index([eventDate])
  @@map("catering_invoice")
}

model CateringInvoiceLineItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int     @map("invoice_id")
  org       String
  type      String // 'SR Catering' | 'SC Catering' | 'TT Catering' | …
  gross     Decimal @db.Decimal(10, 2)
  count     Int? // guest count when known
  btwRate   Decimal @map("btw_rate") @db.Decimal(5, 4)
  notes     String  @default("")

  invoice CateringInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("catering_invoice_line_item")
}

// L1: one-off manual cost line items per ISO week. Recurring patterns and
// formula-driven cells are Phase 4 (RecurringLineItem / ComputedCell).
model ManualLineItem {
  id        Int      @id @default(autoincrement())
  org       String
  year      Int
  week      Int
  label     String
  amount    Decimal  @db.Decimal(10, 2)
  btwRate   Decimal  @map("btw_rate") @db.Decimal(5, 4)
  notes     String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([org, year, week, label])
  @@index([year, week])
  @@map("manual_line_item")
}

// L1: parsed supplier invoices — ALL vendors (food, drinks, overhead), one
// row per invoice, captured by the cowork "invoice pass" (PDF parsing happens
// in Claude sessions; sering-hub/scripts/add-supplier-invoice.ts books the
// result). Richer than FoodcostInvoice, which stays the booking row that
// feeds WeeklyFoodcost: the pass writes BOTH (SupplierInvoice = raw archive
// incl. drinks/overhead portions; FoodcostInvoice = the food booking).
// `categoryTotals` holds the vendor's own breakdown when present (Hanos
// "Splitsing t.b.v. uw administratie").
model SupplierInvoice {
  id            Int      @id @default(autoincrement())
  vendor        String // canonical name, e.g. "Hanos" | "Lindenhoff"
  org           String // west | centraal | testtafel (delivery-address rule)
  invoiceNumber String   @map("invoice_number")
  invoiceDate   String   @map("invoice_date") // YYYY-MM-DD
  year          Int // ISO year/week of invoiceDate
  week          Int
  totalIncl     Decimal  @map("total_incl") @db.Decimal(10, 2)
  totalExcl     Decimal? @map("total_excl") @db.Decimal(10, 2)
  btwLowBase    Decimal? @map("btw_low_base") @db.Decimal(10, 2) // 9% base
  btwHighBase   Decimal? @map("btw_high_base") @db.Decimal(10, 2) // 21% base
  category      String   @default("food") // food | drinks | overhead | mixed
  categoryTotals Json    @default("{}") @map("category_totals")
  driveFileId   String   @default("") @map("drive_file_id")
  notes         String   @default("")
  syncedAt      DateTime @default(now()) @map("synced_at")

  items SupplierInvoiceLineItem[]

  @@unique([vendor, invoiceNumber])
  @@index([year, week])
  @@index([org, year, week])
  @@map("supplier_invoice")
}

model SupplierInvoiceLineItem {
  id            Int     @id @default(autoincrement())
  invoiceId     Int     @map("invoice_id")
  articleNumber String  @default("") @map("article_number")
  description   String
  quantity      Float   @default(0)
  unit          String  @default("") // e.g. "FL. 1000 ML", "ZAK 5 KG"
  unitPrice     Decimal? @map("unit_price") @db.Decimal(10, 4)
  amount        Decimal @db.Decimal(10, 2)
  btwRate       Decimal @map("btw_rate") @db.Decimal(5, 4)
  category      String  @default("") // vendor category hint (Hanos Cd bucket)
  deliveryDate  String  @default("") @map("delivery_date") // YYYY-MM-DD (afleverbon)

  invoice SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([articleNumber])
  @@map("supplier_invoice_line_item")
}

// ── Hub Phase 4: overrides, computed cells, recurring line items (plan §4.4-§4.6) ──
// Hub-only tables. getCellValue() (Hub lib/layers/overrides.ts) reads them at
// L2/L3 read time: a matching active Override wins, else a matching
// ComputedCell's evaluated formula, else the raw L2 value.

// Per-cell correction. Structured columns (not a JSON rowKey) so the key is
// typed + indexable + queryable ("all overrides for week 18"). Which optional
// columns apply depends on tableName (e.g. WeeklyHours uses role; WeeklyRevenue
// uses type+regtype; WeeklyFoodcost uses source). The value is typed —
// valueNumber is Decimal(15,4), wider than money so percentages fit.
model Override {
  id          Int       @id @default(autoincrement())
  tableName   String    @map("table_name")
  org         String
  year        Int
  week        Int?
  date        String?
  role        String?
  source      String?
  type        String?
  regtype     String?
  label       String?
  productName String?   @map("product_name")
  field       String
  valueNumber Decimal?  @map("value_number") @db.Decimal(15, 4)
  valueString String?   @map("value_string")
  valueDate   DateTime? @map("value_date")
  author      String
  reason      String    @default("")
  createdAt   DateTime  @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")
  revokedBy   String?   @map("revoked_by")
  revokeReason String?  @map("revoke_reason")

  @@index([tableName, org, year, week])
  @@map("override")
}

// Formula-driven cell (plan §4.5). Result lands in tableName/label/field for
// the [startYear,startWeek..endYear,endWeek] window; the formula is a small
// expression in the Hub's DSL (weeklyRevenue(org,type), weeklyRevenueTotal(org),
// weeklyGuests(org,meal), weeklyHours(org,role), weeklyFoodcost(org,source) +
// arithmetic). Expanded weekly into WeeklyLineItem during the lineitems
// recompute; honored at read time after a static Override, before raw L2.
model ComputedCell {
  id          Int      @id @default(autoincrement())
  tableName   String   @default("WeeklyLineItem") @map("table_name")
  org         String
  label       String
  field       String   @default("amount")
  startYear   Int      @map("start_year")
  startWeek   Int      @map("start_week")
  endYear     Int?     @map("end_year")
  endWeek     Int?     @map("end_week")
  formula     String
  btwRate     Decimal  @default(0) @map("btw_rate") @db.Decimal(5, 4)
  description String   @default("")
  author      String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([org, startYear, startWeek])
  @@map("computed_cell")
}

// Recurring cost (plan §4.6). org null = sering-wide → split across orgs by
// weekly-revenue share at expansion time. Expanded into WeeklyLineItem for
// every week in [startYear,startWeek..endYear,endWeek]. The TT +720 fixed
// weekly extra is modeled here, not as an override.
model RecurringLineItem {
  id        Int      @id @default(autoincrement())
  org       String?
  label     String
  amount    Decimal  @db.Decimal(10, 2)
  btwRate   Decimal  @map("btw_rate") @db.Decimal(5, 4)
  frequency String   @default("weekly") // "weekly" | "monthly"
  startYear Int      @map("start_year")
  startWeek Int      @map("start_week")
  endYear   Int?     @map("end_year")
  endWeek   Int?     @map("end_week")
  notes     String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([startYear, startWeek])
  @@map("recurring_line_item")
}

// L1: Lightspeed historical exports (TestTafel pre-Tebi). Three CSVs per
// export window: receipts, receipt-items, payments. Re-uploading a window
// replaces items/payments per receipt (no stable per-line upstream id).
model LightspeedReceipt {
  id             Int       @id @default(autoincrement())
  receiptId      String    @unique @map("receipt_id")
  sequenceNumber String    @default("") @map("sequence_number")
  creationDate   DateTime  @map("creation_date")
  finalizedDate  DateTime? @map("finalized_date")
  status         String    @default("")
  tableName      String    @default("") @map("table_name")
  netTotal       Decimal   @map("net_total") @db.Decimal(10, 2)
  total          Decimal   @db.Decimal(10, 2)
  tip            Decimal   @db.Decimal(10, 2)
  taxes          String    @default("") // raw, e.g. "9.0%=34.68 | 21.0%=19.09"
  covers         Int       @default(0)
  sourceFile     String    @default("") @map("source_file")
  syncedAt       DateTime  @default(now()) @map("synced_at")

  @@index([creationDate])
  @@map("lightspeed_receipt")
}

model LightspeedReceiptItem {
  id            Int      @id @default(autoincrement())
  receiptId     String   @map("receipt_id")
  productName   String   @map("product_name")
  category      String   @default("")
  quantity      Float    @default(0)
  gross         Decimal  @db.Decimal(10, 2) // Total Tax Inclusive Price
  taxPercentage Decimal  @map("tax_percentage") @db.Decimal(5, 2) // e.g. 21.00
  creationDate  DateTime @map("creation_date")
  syncedAt      DateTime @default(now()) @map("synced_at")

  @@index([receiptId])
  @@index([creationDate])
  @@map("lightspeed_receipt_item")
}

model LightspeedPayment {
  id          Int      @id @default(autoincrement())
  paymentId   String   @unique @map("payment_id")
  receiptId   String   @map("receipt_id")
  method      String   @default("") // Payment Name, e.g. "Pre payments"
  paymentType String   @default("") @map("payment_type") // Card / Cash
  amount      Decimal  @db.Decimal(10, 2)
  tip         Decimal  @db.Decimal(10, 2)
  createdDate DateTime @map("created_date")
  syncedAt    DateTime @default(now()) @map("synced_at")

  @@index([receiptId])
  @@map("lightspeed_payment")
}

// ── Competencies module ──
// Peer-teaching tracker. A TeachingEvent is the atomic record: a teacher
// taught a learner one Chunk on a date. Competence is derived from this
// history — there is deliberately no "is competent" flag.

model Person {
  id        String   @id
  name      String
  location  String   @default("centraal")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  teachingsGiven    TeachingEvent[] @relation("teacher")
  teachingsReceived TeachingEvent[] @relation("learner")

  @@map("people")
}

model Chunk {
  id            String   @id
  name          String
  station       String
  locations     String[] @default([]) // location tags — Sering Centraal / Sering West / TestTafel
  type          String // "practical" | "sit-down"
  goal          String   @default("")
  prerequisites String[] @default([]) // chunk ids
  requiredFor   String[] @default([]) @map("required_for") // free-text labels
  deeperLink    String?  @map("deeper_link")
  teachingGuide String   @default("") @map("teaching_guide") // markdown
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  teachingEvents TeachingEvent[]

  @@map("chunks")
}

model TeachingEvent {
  id             String   @id
  chunkId        String   @map("chunk_id")
  teacherId      String   @map("teacher_id")
  learnerId      String   @map("learner_id")
  date           String // ISO YYYY-MM-DD
  notes          String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  createdByEmail String   @map("created_by_email")
  createdByName  String   @map("created_by_name")

  chunk   Chunk  @relation(fields: [chunkId], references: [id])
  teacher Person @relation("teacher", fields: [teacherId], references: [id])
  learner Person @relation("learner", fields: [learnerId], references: [id])

  @@index([chunkId])
  @@index([teacherId])
  @@index([learnerId])
  @@map("teaching_events")
}

// ── Drinks module ──
// A unified drinks system across locations: catalogue (bought) + recipe
// (homemade) drinks, costing/pricing, supplier-cycle stocktakes, ordering,
// production logging, write-offs, service cards, assortments + menus. See
// DRINKS_DOMAIN.md for the full domain spec.
//
// Stock is ONE pool per (drink, location) but is stored per storage area in
// DrinkStock and summed — this keeps per-area history so storage tiers can be
// split later (DRINKS_DOMAIN §3). Recipe ingredient rows reference either the
// shared Ingredient DB by a LOOSE id (no Prisma relation — keeps the existing
// Ingredient model byte-for-byte unchanged, per the GOAL touch-point rules) or
// another Drink (building blocks, via the self-relation below). Order lines and
// write-offs likewise use loose ingredient refs so drinks history never couples
// to ingredient lifecycle.

model Drink {
  id       String  @id
  name     String
  mode     String // 'catalogue' | 'recipe'
  category String
  subtype  String  @default("")
  abv      Float   @default(0)
  btwRate  Int?    @map("btw_rate") // null = auto (abv>=0.5 → 21 else 9); overridable
  status   String  @default("draft") // 'draft' | 'published'
  archived Boolean @default(false)
  sellable Boolean @default(true)

  // bought / catalogue fields
  supplier    String  @default("")
  orderUnit   String  @default("") @map("order_unit")
  orderUnitMl Float?  @map("order_unit_ml") // volume of one order unit (keg 20000, bottle 750) — per-serve cost + fractional depletion (Phase 2)
  packNote    String  @default("") @map("pack_note")
  itemId      String? @map("item_id") // supplier order code
  deposit     Float   @default(0) // statiegeld € per order unit
  costPrice   Float?  @map("cost_price") // ex-BTW per order unit
  costNote    String  @default("") @map("cost_note")

  formats          Json     @default("[]") // [{ name, volumeMl, glass?, price: { [loc]: number|null } }]
  locations        Json     @default("{}") // { [loc]: { par: number|null, active: boolean } }
  info             Json     @default("{}") // wine/info: { producer, region, country, vintage, soil, grapes, natural, bio, profile, notes, extra }
  tebiProductNames String[] @default([]) @map("tebi_product_names") // Phase-2 sales reconciliation hook

  // recipe-mode fields
  serveVolumeMl       Float?   @map("serve_volume_ml")
  glass               String   @default("")
  glassVolumeMl       Float?   @map("glass_volume_ml")
  servingTemp         String   @default("") @map("serving_temp")
  characteristics     String[] @default([])
  garnish             String[] @default([])
  seasonality         String   @default("")
  serviceInstructions String   @default("") @map("service_instructions")
  prepSteps           Json     @default("[]") @map("prep_steps") // string[]
  batch               Json     @default("{}") // { volumeMl, bottleSizeMl, note? }
  prepTime            Json     @default("{}") @map("prep_time") // { prebatchMin, prebatchYieldServings?, perServeMin }
  shelfLifeDays       Int?     @map("shelf_life_days")

  // costing cache (computed in M3; ex-BTW per serve)
  costPerServe   Float?  @map("cost_per_serve")
  suggestedPrice Float?  @map("suggested_price")
  photoUrl       String? @map("photo_url") // served URL when a final-product photo exists

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ingredientRows DrinkIngredientRow[] @relation("DrinkOwnsRows")
  usedAsRefIn    DrinkIngredientRow[] @relation("DrinkUsedAsRef")
  stockEntries   DrinkStock[]
  productionLogs DrinkProductionLog[]
  photo          DrinkPhoto?

  @@index([mode])
  @@index([category])
  @@index([status])
  @@index([archived])
  @@map("drinks")
}

model DrinkPhoto {
  id        String @id
  drinkId   String @unique @map("drink_id")
  mimeType  String @map("mime_type")
  data      Bytes
  createdAt String @map("created_at")

  drink Drink @relation(fields: [drinkId], references: [id], onDelete: Cascade)

  @@map("drink_photos")
}

model DrinkIngredientRow {
  id           String  @id
  drinkId      String  @map("drink_id")
  sortOrder    Int     @default(0) @map("sort_order")
  refKind      String  @map("ref_kind") // 'ingredient' | 'drink'
  ingredientId String? @map("ingredient_id") // loose ref into ingredients (no FK — Ingredient model untouched)
  refDrinkId   String? @map("ref_drink_id") // building-block ref → drinks.id
  amount       Float?
  unit         String  @default("ml") // 'ml' | 'g' | 'piece'
  note         String  @default("")

  drink    Drink  @relation("DrinkOwnsRows", fields: [drinkId], references: [id], onDelete: Cascade)
  refDrink Drink? @relation("DrinkUsedAsRef", fields: [refDrinkId], references: [id])

  @@index([drinkId])
  @@index([ingredientId])
  @@index([refDrinkId])
  @@map("drink_ingredient_rows")
}

model DrinkSupplier {
  id             String   @id
  name           String   @unique
  products       String   @default("")
  orderDays      String[] @default([]) @map("order_days")
  orderDaysNote  String   @default("") @map("order_days_note")
  orderCutoff    String   @default("") @map("order_cutoff")
  deliveryWindow String   @default("") @map("delivery_window")
  contact        Json     @default("{}") // { name?, email?, phone?, url?, ... }
  minimumOrder   String   @default("") @map("minimum_order")
  notes          String   @default("")
  priceListRef   String   @default("") @map("price_list_ref")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("drink_suppliers")
}

model DrinkStock {
  id        String    @id
  drinkId   String    @map("drink_id")
  location  String
  area      String    @default("")
  qty       Float     @default(0) // supplier units (decimal allowed)
  countedBy String    @default("") @map("counted_by")
  countedAt DateTime? @map("counted_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  drink Drink @relation(fields: [drinkId], references: [id], onDelete: Cascade)

  @@unique([drinkId, location, area])
  @@index([drinkId])
  @@index([location])
  @@map("drink_stock")
}

model DrinkOrder {
  id               String    @id
  location         String
  supplier         String    @default("")
  status           String    @default("draft") // 'draft'|'ordered'|'received'|'cancelled'
  orderedBy        String?   @map("ordered_by")
  orderedAt        DateTime? @map("ordered_at")
  expectedDelivery String?   @map("expected_delivery") // ISO date
  receivedBy       String?   @map("received_by")
  receivedAt       DateTime? @map("received_at")
  note             String    @default("")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  lines DrinkOrderLine[]

  @@index([location])
  @@index([status])
  @@map("drink_orders")
}

model DrinkOrderLine {
  id            String  @id
  orderId       String  @map("order_id")
  drinkId       String? @map("drink_id") // loose ref → drinks.id (or)
  ingredientId  String? @map("ingredient_id") // loose ref → ingredients.id (shared bar items)
  name          String  @default("")
  orderedQty    Float   @default(0) @map("ordered_qty")
  orderUnit     String  @default("") @map("order_unit")
  receivedQty   Float?  @map("received_qty")
  substitutedBy String? @map("substituted_by")
  deposit       Float   @default(0)
  sortOrder     Int     @default(0) @map("sort_order")

  order DrinkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("drink_order_lines")
}

model DrinkProductionLog {
  id             String   @id
  drinkId        String   @map("drink_id")
  location       String
  batchesMade    Float    @default(0) @map("batches_made")
  volumeMl       Float    @default(0) @map("volume_ml")
  bottlesYielded Float    @default(0) @map("bottles_yielded")
  madeBy         String   @default("") @map("made_by")
  madeOn         String   @map("made_on") // ISO date
  expiresOn      String?  @map("expires_on") // madeOn + shelfLifeDays
  status         String   @default("fresh") // 'fresh'|'expired'|'discarded'
  note           String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")

  drink Drink @relation(fields: [drinkId], references: [id], onDelete: Cascade)

  @@index([drinkId])
  @@index([location])
  @@map("drink_production_logs")
}

model DrinkWriteOff {
  id           String   @id
  refKind      String   @map("ref_kind") // 'drink'|'ingredient'
  drinkId      String?  @map("drink_id") // loose ref
  ingredientId String?  @map("ingredient_id") // loose ref
  name         String   @default("")
  location     String
  qty          Float    @default(0)
  unit         String   @default("")
  reason       String // breakage|spillage|expired|staff-drink|comp|other
  note         String   @default("")
  who          String   @default("")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([refKind])
  @@index([location])
  @@map("drink_write_offs")
}

model Assortment {
  id             String   @id
  name           String
  location       String // 'west'|'centraal'
  serviceContext String   @default("") @map("service_context") // ''|'testtafel'
  description    String   @default("")
  entries        Json     @default("[]") // [{ drinkId, formats?: string[] }]
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  menus DrinkMenu[]

  @@index([location])
  @@map("assortments")
}

model DrinkMenu {
  id           String   @id
  name         String
  assortmentId String   @map("assortment_id")
  location     String
  sections     Json     @default("[]") // [{ title, drinkIds: string[] }]
  layout       Json     @default("{}") // { columns, sectionStyle, typeScale }
  published    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assortment Assortment @relation(fields: [assortmentId], references: [id], onDelete: Cascade)

  @@index([assortmentId])
  @@map("drink_menus")
}

// Singleton module config (id always "default"), mirroring StorageConfig /
// KitchenEquipment. Holds labour rate, price rounding, BTW rule, per-category
// markup targets, demand-nudge threshold, default shelf life.
model DrinkConfig {
  id     String @id @default("default")
  config Json   @default("{}")

  @@map("drink_config")
}
