generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Batch {
  id                String   @id
  name              String
  type              String
  serving           Int      @default(280)
  allergens         String[]
  extraAllergens    String[] @map("extra_allergens")
  orderFor          Boolean  @default(false) @map("order_for")
  cookDate          String?  @map("cook_date")
  note              String   @default("")
  services          Json     @default("[]")
  createdAt         String   @map("created_at")
  recipeId          String?  @map("recipe_id")
  actualIngredients Json?    @map("actual_ingredients")
  cookNotes         String   @default("") @map("cook_notes")
  stockDeducted     Boolean  @default(false) @map("stock_deducted")
  generated         Boolean  @default(false)
  // Unified-batch model: per-(loc,storage) inventory entries + in-flight
  // shipments. The legacy cols (stock/storage/location/inTransit/parentId
  // + v1 recipe fields) and the parent self-FK are removed by the manual
  // drop-cols psql step in prisma/migrations/DEPLOY.md, applied right after
  // data-migrate populates these JSON columns.
  inventory         Json     @default("[]")
  shipments         Json     @default("[]")
  recipe            Recipe?  @relation("BatchRecipe", fields: [recipeId], references: [id])

  @@index([cookDate])
  @@index([recipeId])
  @@map("batches")
}

model Guest {
  id       Int    @id @default(autoincrement())
  location String
  day      String
  lunch    Int    @default(0)
  dinner   Int    @default(0)

  @@unique([location, day])
  @@map("guests")
}

model Catering {
  id             String  @id
  name           String  @default("")
  date           String?
  guestCount     Int     @default(0) @map("guest_count")
  deliveryMode   String  @default("pickup") @map("delivery_mode")
  dishes         Json    @default("[]")
  toppings       Json    @default("[]")
  logisticsNotes String  @default("") @map("logistics_notes")
  createdAt      String  @map("created_at")

  @@map("caterings")
}

model TransportItem {
  id   String @id
  text String

  @@map("transport_items")
}

model Ingredient {
  id               String                @id
  name             String                @default("")
  supplierName     String                @default("") @map("supplier_name")
  types            Json                  @default("[]")
  category         String                @default("")
  unit             String                @default("Grams")
  supplier         String                @default("")
  orderCode        String                @default("") @map("order_code")
  orderUnit        String                @default("") @map("order_unit")
  orderPrice       Float?                @map("order_price")
  priceLevel       String                @default("") @map("price_level")
  priceHistory     Json                  @default("[]") @map("price_history")
  priceAlert       Boolean               @default(false) @map("price_alert")
  storageLocations Json                  @default("{}") @map("storage_locations")
  stock            Json                  @default("{}")
  nutrition        Json                  @default("{}")
  allergens        String                @default("")
  notes            String                @default("")
  active           Boolean               @default(true)
  orderUnitSize    Float                 @default(0) @map("order_unit_size")
  pricePer100      Float                 @default(0) @map("price_per_100")
  measureMode      String                @default("weight") @map("measure_mode")
  targetStock      Json                  @default("{}") @map("target_stock")
  recipeUsages     RecipeIngredientRow[]

  @@index([active])
  @@index([category])
  @@map("ingredients")
}

model GuestHistory {
  id       Int    @id @default(autoincrement())
  location String
  meal     String
  date     String
  count    Int    @default(0)

  @@unique([location, meal, date])
  @@map("guest_history")
}

model GuestHistoryMeta {
  key   String @id
  value String

  @@map("guest_history_meta")
}

model GuestsNextWeeks {
  id        Int    @id @default(autoincrement())
  mondayKey String @map("monday_key")
  location  String
  day       String
  meal      String
  count     Int    @default(0)

  @@unique([mondayKey, location, day, meal])
  @@index([mondayKey])
  @@map("guests_next_weeks")
}

model Log {
  id        Int    @id @default(autoincrement())
  timestamp String
  email     String
  name      String
  action    String
  details   String

  @@index([timestamp])
  @@map("log")
}

// Active login sessions. Previously held in-process in a Map, which meant
// every Railway redeploy logged everyone out (the cookie was still valid for
// 7 days but the in-memory state was gone). Persisting here closes the
// "I keep getting logged off" feedback loop and also removes a multi-replica
// blocker. expiresAt mirrors the cookie's maxAge.
model Session {
  id        String   @id
  email     String
  name      String
  picture   String?
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("sessions")
}

// Account-access requests + grants. The effective login allowlist is the
// union of CONFIG.ALLOWED_EMAILS (env, the bootstrap backbone) and the rows
// here with status="approved". A new person signs in with Google, which
// records a "pending" row; a director approves it (status -> "approved") and
// the person can then log in — no env-var edit / redeploy needed. Revoking an
// approved user flips status to "revoked". Env-listed emails are never stored
// here and can't be revoked from the UI (so a director can't lock themselves
// out). See routes/auth.ts (isEmailAllowed) and routes/access.ts.
model AccessRequest {
  id          String    @id
  email       String    @unique
  name        String // display name = "firstName lastName" (or the Google name on the auto-queue fallback)
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  picture     String?
  status      String    @default("pending") // "pending" | "approved" | "denied" | "revoked"
  requestedAt DateTime  @default(now()) @map("requested_at")
  decidedAt   DateTime? @map("decided_at")
  decidedBy   String?   @map("decided_by") // director email who approved/denied/revoked
  // Training (competencies) person created/linked on approval. Lets the
  // approved account be the source of that person's name; see routes/access.ts.
  personId    String?   @map("person_id")
  // Role-based page permissions. Null = full edit (preserves legacy behavior for
  // env-listed / pre-role users); a non-null role maps each screen to a level.
  roleId      String?   @map("role_id")

  @@index([status])
  @@map("access_requests")
}

// Role-based page permissions — frontend guardrails only (no server-side write
// enforcement). `permissions` maps each gateable screen id to
// "hidden" | "view" | "edit"; an AccessRequest.roleId links a user to one role.
// Directors (DIRECTOR_EMAILS) bypass roles entirely (full edit). Resolved into
// the AppUser at login / GET /auth/me — see routes/auth.ts (resolvePermissions)
// and the frontend nav/view gating in public/js/navigate.ts.
model Role {
  id          String   @id
  name        String
  permissions Json     @default("{}") // { [screenId]: "hidden" | "view" | "edit" }
  isDefault   Boolean  @default(false) @map("is_default") // assigned to newly-approved users
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Feedback {
  id        Int     @id @default(autoincrement())
  timestamp String
  user      String  @default("anonymous")
  type      String  @default("general")
  screen    String  @default("")
  text      String
  userAgent String  @default("") @map("user_agent")
  processed Boolean @default(false)

  @@index([processed])
  @@map("feedback")
}

model StandardInventory {
  id       String @id
  name     String
  amount   Float
  unit     String
  location String @default("west")

  @@map("standard_inventory")
}

model PrepChecklist {
  id        Int      @id @default(autoincrement())
  loc       String
  date      String
  checked   Json     @default("[]")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([loc, date])
  @@map("prep_checklist")
}

// Per-(location, date) set of completed daily-ritual step keys (e.g.
// "fmm-lunch", "service-dinner", "stocktake"). Backs the dashboard "Today"
// guidance panel. Modelled exactly on PrepChecklist: a JSON array of done
// step-key strings, overwritten wholesale on save so tick/untick is trivial.
// Only steps with no observable domain signal are stored here; steps backed
// by real state (inventory, cookDate, shipments) are derived, never stored.
model RitualCompletion {
  id        Int      @id @default(autoincrement())
  loc       String
  date      String
  completed Json     @default("[]")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([loc, date])
  @@map("ritual_completions")
}

model StorageConfig {
  id     String @id @default("default")
  config Json   @default("{}")

  @@map("storage_config")
}

model KitchenEquipment {
  id                 String @id @default("default")
  pots               Json   @default("[]") // array of liter sizes, e.g. [140, 140, 100, 100, ...]
  gasBurners         Int    @default(0) @map("gas_burners") // burners that can handle pots > 80L
  inductionBurners   Int    @default(0) @map("induction_burners") // burners that handle pots ≤ 80L
  bigBurnerThreshold Int    @default(80) @map("big_burner_threshold") // pot size that requires a gas burner

  @@map("kitchen_equipment")
}

model CookRhythm {
  id     String @id @default("default")
  config Json   @default("{}") // { days: { Mon: { soup, main, chefs }, ... } } — editable Fix My Menu rules

  @@map("cook_rhythm")
}

model ClosedServices {
  id     String @id @default("default")
  config Json   @default("{}") // { recurring: { <loc>: { <weekday>: Meal[] } }, dates?: {...} } — closed-service schedule

  @@map("closed_services")
}

model DailyRevenue {
  id           Int    @id @default(autoincrement())
  date         String
  location     String
  grossRevenue Float  @default(0) @map("gross_revenue")
  netRevenue   Float  @default(0) @map("net_revenue")
  sales        Int    @default(0)
  covers       Int    @default(0)
  invoiceCount Int    @default(0) @map("invoice_count")
  syncedAt     String @map("synced_at")

  @@unique([date, location])
  @@map("daily_revenue")
}

model ProductRevenue {
  id              Int    @id @default(autoincrement())
  date            String
  location        String
  meal            String
  productName     String @map("product_name")
  productCategory String @default("") @map("product_category")
  quantity        Float  @default(0)
  grossRevenue    Float  @default(0) @map("gross_revenue")
  netRevenue      Float  @default(0) @map("net_revenue")
  syncedAt        String @map("synced_at")

  @@unique([date, location, meal, productName])
  @@map("product_revenue")
}

model Recipe {
  id             String                @id
  name           String
  type           String                @default("Soup")
  structure      String                @default("")
  seasonality    String                @default("")
  servingTemp    String                @default("") @map("serving_temp")
  servingSize    Int                   @default(280) @map("serving_size")
  recipeVolume   Float?                @map("recipe_volume")
  // Yield mode: 'volume' (soups/mains — scaled by liters, the default when
  // null) or 'count' (toppings & bread — scaled by discrete outputCount of
  // outputUnit, e.g. "makes 10 loaves").
  yieldType      String?               @map("yield_type")
  outputCount    Float?                @map("output_count")
  outputUnit     String?               @map("output_unit")
  autoAllergens  String[]              @map("auto_allergens")
  extraAllergens String[]              @map("extra_allergens")
  costPerServing Float?                @map("cost_per_serving")
  avgSkill       Float                 @default(0) @map("avg_skill")
  avgSpeed       Float                 @default(0) @map("avg_speed")
  avgBanger      Float                 @default(0) @map("avg_banger")
  timesServed    Int                   @default(0) @map("times_served")
  prepSteps      Json                  @default("[]") @map("prep_steps")
  coolingMethod  String                @default("") @map("cooling_method")
  storageMethod  String                @default("") @map("storage_method")
  photoUrl       String?               @map("photo_url")
  isComplete     Boolean               @default(false) @map("is_complete")
  versions       Json                  @default("[]")
  createdBy      String                @default("") @map("created_by")
  createdAt      String                @map("created_at")
  updatedAt      String                @map("updated_at")
  legacySheetId  String?               @map("legacy_sheet_id")
  batches        Batch[]               @relation("BatchRecipe")
  ingredients    RecipeIngredientRow[]
  photo          RecipePhoto?
  supplies       Supply[]              @relation("SupplyRecipe")

  @@index([type])
  @@map("recipes")
}

// Supply: toppings, breads, ferments, pickles, sauces. Standard supplies have a
// per-guest ratio + replenishment; one-offs drip-feed across services until
// depleted, then auto-archive. preservationMethod is a tag for a future
// PreservationProject feature (Lacto ferment / Sugar preservation / etc.) — see
// the planning doc; out of scope for this PR.
model Supply {
  id                 String   @id
  name               String
  kind               String   // 'standard' | 'oneoff'
  unit               String   // 'g' | 'pieces' | 'jars' | 'ml' | ...
  recipeId           String?  @map("recipe_id")
  recipe             Recipe?  @relation("SupplyRecipe", fields: [recipeId], references: [id])

  // standard-only fields (null for oneoff)
  guestsPerUnit      Float?   @map("guests_per_unit")  // guests served by one unit (e.g. 10 = 1 box per 10 guests)
  prepHorizonDays    Int?     @map("prep_horizon_days")
  prepMode           String?  @map("prep_mode")  // 'centralized' | 'per-location'

  // oneoff-only fields (null for standard)
  oneoffLocation     String?  @map("oneoff_location")  // 'west' | 'centraal'
  unitsPerService    Float?   @map("units_per_service")
  oneoffStartDate    String?  @map("oneoff_start_date")  // ISO 'YYYY-MM-DD'

  stock              Json     @default("{}")  // { west: { amount, lastMakeDate }, centraal: { amount, lastMakeDate } }
  costPerUnit        Float?   @map("cost_per_unit")  // € per unit; drives price-per-guest = costPerUnit / guestsPerUnit
  preservationMethod String?  @map("preservation_method")
  archived           Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([archived])
  @@index([kind])
  @@map("supplies")
}

model RecipeIngredientRow {
  id             String      @id
  recipeId       String      @map("recipe_id")
  ingredientId   String?     @map("ingredient_id")
  sortOrder      Int         @default(0) @map("sort_order")
  rawAmount      Float       @map("raw_amount")
  cookedAmount   Float?      @map("cooked_amount")
  unit           String      @default("Grams")
  isFlexible     Boolean     @default(false) @map("is_flexible")
  flexCategory   String?     @map("flex_category")
  flexLabel      String?     @map("flex_label")
  suggestedNames String[]    @map("suggested_names")
  ingredient     Ingredient? @relation(fields: [ingredientId], references: [id])
  recipe         Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

model RecipePhoto {
  id        String @id
  recipeId  String @unique @map("recipe_id")
  mimeType  String @map("mime_type")
  data      Bytes
  createdAt String @map("created_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_photos")
}

model TelemetryEvent {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  source    String
  type      String
  name      String
  data      Json?
  userId    String?  @map("user_id")
  sessionId String?  @map("session_id")

  @@index([timestamp])
  @@index([type, timestamp])
  @@index([source, type])
  @@map("telemetry_event")
}

model AiInsight {
  id         Int       @id @default(autoincrement())
  timestamp  DateTime  @default(now())
  category   String
  severity   String
  title      String
  body       String
  data       Json?
  status     String    @default("new")
  resolvedAt DateTime? @map("resolved_at")

  @@index([status, timestamp])
  @@index([category])
  @@map("ai_insight")
}

// ── Competencies module ──
// Peer-teaching tracker. A TeachingEvent is the atomic record: a teacher
// taught a learner one Chunk on a date. Competence is derived from this
// history — there is deliberately no "is competent" flag.

model Person {
  id        String   @id
  name      String
  location  String   @default("centraal")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  teachingsGiven    TeachingEvent[] @relation("teacher")
  teachingsReceived TeachingEvent[] @relation("learner")

  @@map("people")
}

model Chunk {
  id            String   @id
  name          String
  station       String
  locations     String[] @default([]) // location tags — Sering Centraal / Sering West / TestTafel
  type          String // "practical" | "sit-down"
  goal          String   @default("")
  prerequisites String[] @default([]) // chunk ids
  requiredFor   String[] @default([]) @map("required_for") // free-text labels
  deeperLink    String?  @map("deeper_link")
  teachingGuide String   @default("") @map("teaching_guide") // markdown
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  teachingEvents TeachingEvent[]

  @@map("chunks")
}

model TeachingEvent {
  id             String   @id
  chunkId        String   @map("chunk_id")
  teacherId      String   @map("teacher_id")
  learnerId      String   @map("learner_id")
  date           String // ISO YYYY-MM-DD
  notes          String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  createdByEmail String   @map("created_by_email")
  createdByName  String   @map("created_by_name")

  chunk   Chunk  @relation(fields: [chunkId], references: [id])
  teacher Person @relation("teacher", fields: [teacherId], references: [id])
  learner Person @relation("learner", fields: [learnerId], references: [id])

  @@index([chunkId])
  @@index([teacherId])
  @@index([learnerId])
  @@map("teaching_events")
}

// ── Drinks module ──
// A unified drinks system across locations: catalogue (bought) + recipe
// (homemade) drinks, costing/pricing, supplier-cycle stocktakes, ordering,
// production logging, write-offs, service cards, assortments + menus. See
// DRINKS_DOMAIN.md for the full domain spec.
//
// Stock is ONE pool per (drink, location) but is stored per storage area in
// DrinkStock and summed — this keeps per-area history so storage tiers can be
// split later (DRINKS_DOMAIN §3). Recipe ingredient rows reference either the
// shared Ingredient DB by a LOOSE id (no Prisma relation — keeps the existing
// Ingredient model byte-for-byte unchanged, per the GOAL touch-point rules) or
// another Drink (building blocks, via the self-relation below). Order lines and
// write-offs likewise use loose ingredient refs so drinks history never couples
// to ingredient lifecycle.

model Drink {
  id       String  @id
  name     String
  mode     String // 'catalogue' | 'recipe'
  category String
  subtype  String  @default("")
  abv      Float   @default(0)
  btwRate  Int?    @map("btw_rate") // null = auto (abv>=0.5 → 21 else 9); overridable
  status   String  @default("draft") // 'draft' | 'published'
  archived Boolean @default(false)
  sellable Boolean @default(true)

  // bought / catalogue fields
  supplier    String  @default("")
  orderUnit   String  @default("") @map("order_unit")
  orderUnitMl Float?  @map("order_unit_ml") // volume of one order unit (keg 20000, bottle 750) — per-serve cost + fractional depletion (Phase 2)
  packNote    String  @default("") @map("pack_note")
  itemId      String? @map("item_id") // supplier order code
  deposit     Float   @default(0) // statiegeld € per order unit
  costPrice   Float?  @map("cost_price") // ex-BTW per order unit
  costNote    String  @default("") @map("cost_note")

  formats          Json     @default("[]") // [{ name, volumeMl, glass?, price: { [loc]: number|null } }]
  locations        Json     @default("{}") // { [loc]: { par: number|null, active: boolean } }
  info             Json     @default("{}") // wine/info: { producer, region, country, vintage, soil, grapes, natural, bio, profile, notes, extra }
  tebiProductNames String[] @default([]) @map("tebi_product_names") // Phase-2 sales reconciliation hook

  // recipe-mode fields
  serveVolumeMl       Float?   @map("serve_volume_ml")
  glass               String   @default("")
  glassVolumeMl       Float?   @map("glass_volume_ml")
  servingTemp         String   @default("") @map("serving_temp")
  characteristics     String[] @default([])
  garnish             String[] @default([])
  seasonality         String   @default("")
  serviceInstructions String   @default("") @map("service_instructions")
  prepSteps           Json     @default("[]") @map("prep_steps") // string[]
  batch               Json     @default("{}") // { volumeMl, bottleSizeMl, note? }
  prepTime            Json     @default("{}") @map("prep_time") // { prebatchMin, prebatchYieldServings?, perServeMin }
  shelfLifeDays       Int?     @map("shelf_life_days")

  // costing cache (computed in M3; ex-BTW per serve)
  costPerServe   Float? @map("cost_per_serve")
  suggestedPrice Float? @map("suggested_price")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ingredientRows DrinkIngredientRow[] @relation("DrinkOwnsRows")
  usedAsRefIn    DrinkIngredientRow[] @relation("DrinkUsedAsRef")
  stockEntries   DrinkStock[]
  productionLogs DrinkProductionLog[]

  @@index([mode])
  @@index([category])
  @@index([status])
  @@index([archived])
  @@map("drinks")
}

model DrinkIngredientRow {
  id           String  @id
  drinkId      String  @map("drink_id")
  sortOrder    Int     @default(0) @map("sort_order")
  refKind      String  @map("ref_kind") // 'ingredient' | 'drink'
  ingredientId String? @map("ingredient_id") // loose ref into ingredients (no FK — Ingredient model untouched)
  refDrinkId   String? @map("ref_drink_id") // building-block ref → drinks.id
  amount       Float?
  unit         String  @default("ml") // 'ml' | 'g' | 'piece'
  note         String  @default("")

  drink    Drink  @relation("DrinkOwnsRows", fields: [drinkId], references: [id], onDelete: Cascade)
  refDrink Drink? @relation("DrinkUsedAsRef", fields: [refDrinkId], references: [id])

  @@index([drinkId])
  @@index([ingredientId])
  @@index([refDrinkId])
  @@map("drink_ingredient_rows")
}

model DrinkSupplier {
  id             String   @id
  name           String   @unique
  products       String   @default("")
  orderDays      String[] @default([]) @map("order_days")
  orderDaysNote  String   @default("") @map("order_days_note")
  orderCutoff    String   @default("") @map("order_cutoff")
  deliveryWindow String   @default("") @map("delivery_window")
  contact        Json     @default("{}") // { name?, email?, phone?, url?, ... }
  minimumOrder   String   @default("") @map("minimum_order")
  notes          String   @default("")
  priceListRef   String   @default("") @map("price_list_ref")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("drink_suppliers")
}

model DrinkStock {
  id        String    @id
  drinkId   String    @map("drink_id")
  location  String
  area      String    @default("")
  qty       Float     @default(0) // supplier units (decimal allowed)
  countedBy String    @default("") @map("counted_by")
  countedAt DateTime? @map("counted_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  drink Drink @relation(fields: [drinkId], references: [id], onDelete: Cascade)

  @@unique([drinkId, location, area])
  @@index([drinkId])
  @@index([location])
  @@map("drink_stock")
}

model DrinkOrder {
  id               String    @id
  location         String
  supplier         String    @default("")
  status           String    @default("draft") // 'draft'|'ordered'|'received'|'cancelled'
  orderedBy        String?   @map("ordered_by")
  orderedAt        DateTime? @map("ordered_at")
  expectedDelivery String?   @map("expected_delivery") // ISO date
  receivedBy       String?   @map("received_by")
  receivedAt       DateTime? @map("received_at")
  note             String    @default("")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  lines DrinkOrderLine[]

  @@index([location])
  @@index([status])
  @@map("drink_orders")
}

model DrinkOrderLine {
  id            String  @id
  orderId       String  @map("order_id")
  drinkId       String? @map("drink_id") // loose ref → drinks.id (or)
  ingredientId  String? @map("ingredient_id") // loose ref → ingredients.id (shared bar items)
  name          String  @default("")
  orderedQty    Float   @default(0) @map("ordered_qty")
  orderUnit     String  @default("") @map("order_unit")
  receivedQty   Float?  @map("received_qty")
  substitutedBy String? @map("substituted_by")
  deposit       Float   @default(0)
  sortOrder     Int     @default(0) @map("sort_order")

  order DrinkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("drink_order_lines")
}

model DrinkProductionLog {
  id             String   @id
  drinkId        String   @map("drink_id")
  location       String
  batchesMade    Float    @default(0) @map("batches_made")
  volumeMl       Float    @default(0) @map("volume_ml")
  bottlesYielded Float    @default(0) @map("bottles_yielded")
  madeBy         String   @default("") @map("made_by")
  madeOn         String   @map("made_on") // ISO date
  expiresOn      String?  @map("expires_on") // madeOn + shelfLifeDays
  status         String   @default("fresh") // 'fresh'|'expired'|'discarded'
  note           String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")

  drink Drink @relation(fields: [drinkId], references: [id], onDelete: Cascade)

  @@index([drinkId])
  @@index([location])
  @@map("drink_production_logs")
}

model DrinkWriteOff {
  id           String   @id
  refKind      String   @map("ref_kind") // 'drink'|'ingredient'
  drinkId      String?  @map("drink_id") // loose ref
  ingredientId String?  @map("ingredient_id") // loose ref
  name         String   @default("")
  location     String
  qty          Float    @default(0)
  unit         String   @default("")
  reason       String // breakage|spillage|expired|staff-drink|comp|other
  note         String   @default("")
  who          String   @default("")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([refKind])
  @@index([location])
  @@map("drink_write_offs")
}

model Assortment {
  id             String   @id
  name           String
  location       String // 'west'|'centraal'
  serviceContext String   @default("") @map("service_context") // ''|'testtafel'
  description    String   @default("")
  entries        Json     @default("[]") // [{ drinkId, formats?: string[] }]
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  menus DrinkMenu[]

  @@index([location])
  @@map("assortments")
}

model DrinkMenu {
  id           String   @id
  name         String
  assortmentId String   @map("assortment_id")
  location     String
  sections     Json     @default("[]") // [{ title, drinkIds: string[] }]
  layout       Json     @default("{}") // { columns, sectionStyle, typeScale }
  published    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assortment Assortment @relation(fields: [assortmentId], references: [id], onDelete: Cascade)

  @@index([assortmentId])
  @@map("drink_menus")
}

// Singleton module config (id always "default"), mirroring StorageConfig /
// KitchenEquipment. Holds labour rate, price rounding, BTW rule, per-category
// markup targets, demand-nudge threshold, default shelf life.
model DrinkConfig {
  id     String @id @default("default")
  config Json   @default("{}")

  @@map("drink_config")
}
