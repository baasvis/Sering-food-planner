{
  "name": "sering-food-planner",
  "version": "2.0.0",
  "description": "De Sering food planning app",
  "main": "dist/server/server.js",
  "scripts": {
    "start": "node dist/server/server.js",
    "dev": "concurrently \"npx vite --config vite.config.ts\" \"npx tsx watch server.ts\"",
    "dev:server": "npx tsx watch server.ts",
    "build": "npx vite build --config vite.config.ts && npx tsc -p tsconfig.server.json",
    "preview": "npm run build && cross-env NODE_ENV=production node dist/server/server.js",
    "postinstall": "prisma generate && cross-env PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install --with-deps chromium",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm test && npm run test:e2e",
    "telemetry:mine": "tsx scripts/mine-telemetry-journeys.ts",
    "typecheck": "npx tsc -p tsconfig.server.json --noEmit"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@prisma/client": "~6.19.2",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.6.0",
    "googleapis": "^128.0.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "playwright": "~1.58.2",
    "prisma": "~6.19.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "jest": {
    "transform": {
      "^.+\\.ts$": [
        "@swc/jest"
      ]
    },
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "setupFiles": [
      "<rootDir>/test/setup-env.ts",
      "<rootDir>/test/setup-dom-stubs.ts"
    ],
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/shared/$1"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@playwright/test": "~1.58.2",
    "@swc/core": "~1.15.21",
    "@swc/jest": "~0.2.39",
    "@types/express": "~5.0.6",
    "@types/node": "~25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "~10.1.0",
    "jest": "~30.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "~8.0.3"
  }
}
