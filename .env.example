# Shared secret for both the PWA API and the MCP endpoint.
# Generate one with: openssl rand -hex 24
NOTES_SECRET=

# Postgres connection string (Railway provides this automatically when you
# add the Postgres plugin). Without it the server falls back to a local
# JSON file in ./data/notes.json — fine for development, not for production.
DATABASE_URL=

# Port to listen on (Railway sets this automatically)
PORT=3000
