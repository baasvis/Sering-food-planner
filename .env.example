# PostgreSQL connection (required)
DATABASE_URL=postgresql://user:password@localhost:5432/sering

# Google OAuth client ID — for user login
# If empty, runs in dev mode (no auth required)
GOOGLE_CLIENT_ID=

# Google service account credentials (JSON string)
# Used for reading external recipe sheets only
GOOGLE_CREDENTIALS={}

# Comma-separated list of allowed email addresses
# If empty, anyone with a Google account can log in
ALLOWED_EMAILS=

# Server port (default: 3000)
# PORT=3000
